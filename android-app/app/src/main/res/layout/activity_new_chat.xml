<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_panel" />

    <TextView
        android:id="@+id/statusBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_panel_alt"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:textColor="@color/text_muted"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_working_directory"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/cwdInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card"
                    android:hint="@string/hint_cwd"
                    android:inputType="text"
                    android:minHeight="54dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="14dp"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_muted" />

                <Button
                    android:id="@+id/browseCwdButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/action_browse_folders"
                    android:textAllCaps="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/hint_missing_cwd_created"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/label_opening_message"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/promptInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card"
                    android:gravity="top|start"
                    android:hint="@string/hint_opening_message"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minHeight="96dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="14dp"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_muted" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/label_note"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/noteInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card"
                    android:hint="@string/hint_note_optional"
                    android:inputType="textCapSentences"
                    android:minHeight="54dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="14dp"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_muted" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/label_model"
                    android:textColor="@color/text_muted" />

                <Spinner
                    android:id="@+id/modelSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_approval"
                    android:textColor="@color/text_muted" />

                <Spinner
                    android:id="@+id/approvalSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_sandbox"
                    android:textColor="@color/text_muted" />

                <Spinner
                    android:id="@+id/sandboxSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_reasoning"
                    android:textColor="@color/text_muted" />

                <Spinner
                    android:id="@+id/reasoningSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <Button
                android:id="@+id/createChatButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:minHeight="54dp"
                android:text="@string/action_create_chat" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>


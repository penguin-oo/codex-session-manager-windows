<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_panel" />

    <TextView
        android:id="@+id/headerMetaText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_panel"
        android:ellipsize="end"
        android:maxLines="2"
        android:paddingHorizontal="18dp"
        android:paddingBottom="14dp"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/statusBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_panel_alt"
        android:ellipsize="end"
        android:maxLines="2"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:textColor="@color/text_muted"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messageRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />

        <FrameLayout
            android:id="@+id/fastScrollTrackContainer"
            android:layout_width="24dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:layout_marginEnd="6dp"
            android:elevation="6dp"
            android:paddingVertical="16dp"
            android:visibility="gone">

            <View
                android:id="@+id/fastScrollTrack"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:layout_gravity="end|center_vertical"
                android:background="@drawable/bg_fast_scroll_track" />

            <View
                android:id="@+id/fastScrollThumb"
                android:layout_width="8dp"
                android:layout_height="72dp"
                android:layout_gravity="end|top"
                android:background="@drawable/bg_fast_scroll_thumb" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/scrollJumpButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_marginBottom="16dp"
            android:layout_marginEnd="28dp"
            android:elevation="8dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/jumpToTopButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_card"
                android:contentDescription="@string/action_jump_to_top"
                android:padding="10dp"
                android:src="@android:drawable/arrow_up_float"
                android:tint="@color/text_main"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/jumpToBottomButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_card"
                android:contentDescription="@string/action_jump_to_bottom"
                android:padding="10dp"
                android:src="@android:drawable/arrow_down_float"
                android:tint="@color/text_main"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/composerPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_panel"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:id="@+id/attachmentPreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_card_active"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/attachmentPreviewImage"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_card"
                android:contentDescription="@string/label_selected_image"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/attachmentPreviewTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_selected_image"
                    android:textColor="@color/text_main"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/attachmentPreviewSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/clearAttachmentButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_card"
                android:contentDescription="@string/label_remove_image"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/text_main" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/composerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/attachImageButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_card"
                android:contentDescription="@string/action_attach_image"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:tint="@color/accent_main" />

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="top|start"
                android:hint="Message Codex"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="6"
                android:minLines="1"
                android:overScrollMode="ifContentScrolls"
                android:paddingHorizontal="14dp"
                android:paddingVertical="14dp"
                android:scrollbars="vertical"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_muted" />

            <Button
                android:id="@+id/sendButton"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginStart="10dp"
                android:backgroundTint="@color/accent_main"
                android:paddingHorizontal="18dp"
                android:text="@string/action_send"
                android:textAllCaps="false"
                android:textColor="@color/bg_app" />

            <Button
                android:id="@+id/stopButton"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginStart="10dp"
                android:backgroundTint="@color/accent_main"
                android:paddingHorizontal="18dp"
                android:text="@string/action_stop"
                android:textAllCaps="false"
                android:textColor="@color/bg_app"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
